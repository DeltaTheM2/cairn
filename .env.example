# Cairn — environment variables
# Copy this to .env.local and fill in values. Never commit .env.local.

# ---------- Database ----------
# MySQL 8 on wizardtools (or local for dev). Use a separate DB for tests.
DATABASE_URL=mysql://user:password@host:3306/cairn
DATABASE_URL_TEST=mysql://user:password@host:3306/cairn_test

# ---------- Auth.js v5 ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-32-byte-random-string

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Magic link via Resend — https://resend.com/api-keys
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="Cairn <noreply@your-domain.com>"

# Public app URL (used in callback URLs and emails)
AUTH_URL=http://localhost:3000

# ---------- LLM ----------
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Set ANTHROPIC_API_KEY=fake to use the mock provider during dev/UI work.

# ---------- Observability (v1, not MVP) ----------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Misc ----------
# Storage path for synthesized doc exports (PDF/DOCX cache).
# Default fine for dev; production points to a persistent volume.
EXPORT_STORAGE_PATH=./storage/exports
